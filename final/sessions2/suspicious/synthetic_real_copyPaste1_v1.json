a0\u00a0\u00a0\u00a0\u00a0\n\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0//\u00a0Return\u00a0the\u00a0actual\u00a0head\u00a0of\u00a0result\u00a0list\u00a0(skip\u00a0dummy\u00a0head)\n\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0return\u00a0dummyHead.next;\n\u00a0\u00a0\u00a0\u00a0}\n}\n"
